<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.0.xsd
        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <changeSet id="2026-03-02-Items.xml" author="Dmitry">
        <createTable tableName="items">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" unique="true" primaryKey="true"/>
            </column>
            <column name="exercise_id" type="BIGINT">
                <constraints nullable="false" unique="false" references="exercise(id)" foreignKeyName="fk_items_exercise"/>
            </column>
            <column name="inventory_id" type="BIGINT">
                <constraints nullable="false" unique="false" references="inventory(id)" foreignKeyName="fk_items_inventory"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>